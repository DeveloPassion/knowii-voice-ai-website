{
    "name": "knowii-voice-ai-website",
    "private": true,
    "version": "0.0.1",
    "description": "Marketing website for Knowii Voice AI",
    "author": "DeveloPassion",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DeveloPassion/knowii-voice-ai-website.git"
    },
    "bugs": {
        "url": "https://github.com/DeveloPassion/knowii-voice-ai-website/issues"
    },
    "homepage": "https://voice-ai.knowii.net",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "dev": "bun scripts/dev.ts",
        "build": "bun run tsc && bun scripts/build.ts --prod",
        "preview": "bun run build && bun scripts/serve.ts",
        "serve": "bun scripts/serve.ts",
        "setup": "git config --local --replace-all include.path ../.gitconfig",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "tsc": "tsc --noEmit",
        "tsc:watch": "tsc --noEmit --watch --preserveWatchOutput",
        "tscw": "bun run tsc:watch",
        "test": "bun test",
        "validate": "bun run --parallel tsc test lint",
        "commit": "cz",
        "cm": "bun run commit",
        "commit:lint": "commitlint --from HEAD~1 --to HEAD --verbose",
        "release": "read -p 'Enter tag name: ' TAG && git tag \"$TAG\" && git push origin \"$TAG\" && echo \"Tag $TAG created and pushed. Deployment will start automatically.\""
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-customizable"
        },
        "cz-customizable": {
            "config": ".cz-config.cjs"
        }
    },
    "engines": {
        "node": ">=20.0",
        "npm": ">=10.1.0"
    },
    "dependencies": {
        "clsx": "2.1.1",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-icons": "5.6.0",
        "react-router": "8.0.0",
        "tailwind-merge": "3.6.0"
    },
    "devDependencies": {
        "@commitlint/cli": "21.0.2",
        "@commitlint/config-conventional": "21.0.2",
        "@eslint/js": "10.0.1",
        "@tailwindcss/cli": "4.3.1",
        "@types/bun": "1.3.14",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "commitizen": "4.3.2",
        "cz-customizable": "7.5.4",
        "eslint": "10.5.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "globals": "17.6.0",
        "prettier": "3.8.4",
        "prettier-plugin-tailwindcss": "0.8.0",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.1"
    }
}
